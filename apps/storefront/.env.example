# ===== STOREFRONT =====

# Public URL of your Medusa backend.
# When unset, the storefront falls back to its built-in /api/store mock (useful for local dev).
# Once you've deployed Medusa to your VPS, set this to the real API:
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.eledante.builtbymar.net

# Publishable API key for the Storefront sales channel.
# Create one in the Medusa admin under Settings → Publishable API Keys, then assign it to the 'Eledante Storefront' sales channel.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me

# Stripe publishable key (client-side, used by Medusa's Stripe payment session).
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_KEY=pk_test_replace_me

# Internal canonical URL of this storefront (used in metadata, sitemap, OG tags).
NEXT_PUBLIC_BASE_URL=https://eledante.builtbymar.net
