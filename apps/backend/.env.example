# ===== REQUIRED =====

# Neon Postgres connection string (free tier works fine).
# Get from https://console.neon.tech -- create a project, copy the pooled or direct connection string.
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/eledante?sslmode=require
DATABASE_URL=

# CORS — list every origin that will talk to this backend, comma-separated.
STORE_CORS=https://eledante.builtbymar.net,http://localhost:3100
ADMIN_CORS=https://api.eledante.builtbymar.net,http://localhost:9000
AUTH_CORS=https://eledante.builtbymar.net,https://api.eledante.builtbymar.net,http://localhost:3100,http://localhost:9000

# Secrets — generate with `openssl rand -base64 48`.
JWT_SECRET=replace-me
COOKIE_SECRET=replace-me

# Public URL of this backend (used by the bundled Medusa admin SPA).
MEDUSA_BACKEND_URL=https://api.eledante.builtbymar.net

# ===== PAYMENTS =====

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# iyzico (v2 — deferred to pass 2)
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ===== OPTIONAL =====
# DISABLE_MEDUSA_ADMIN=false
